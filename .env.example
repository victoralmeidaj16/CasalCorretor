# Exemplo de configuração de variáveis de ambiente
# Copie este arquivo e renomeie para `.env.local` na raiz do projeto.

# Chave de API da OpenAI (Simulações de Rota)
OPENAI_API_KEY=sua_chave_openai_aqui

# Chave de API da Google AI / Gemini (Geração de Conteúdo e Imagens)
GOOGLE_AI_API_KEY=sua_chave_google_ai_aqui

# Configurações de Modelos (Opcional - Valores padrão serão usados se vazios)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
